{
  "name": "warehouse-system",
  "version": "1.0.0",
  "description": "仓库进销存管理系统",
  "main": "store.js",
  "scripts": {
    "start": "node store.js",
    "test": "jest --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "multer": "^2.2.0",
    "mysql2": "^3.9.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
